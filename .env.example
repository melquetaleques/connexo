# ============================================================
# Connexo — Environment Variables (Production)
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# Then edit .env with your actual secrets.
# ============================================================

# --- Database ---
# Full PostgreSQL connection URL
CONNEXO_DATABASE_URL=postgres://postgres:changeme@localhost:5432/connexo?sslmode=disable
# Database password (used in docker-compose.prod.yml)
CONNEXO_DB_PASSWORD=changeme

# --- Redis ---
# Full Redis connection URL
CONNEXO_REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# JWT secret key (generate with: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-random-64-byte-hex-string
# JWT token expiry in hours (default: 72)
JWT_EXPIRY_HOURS=72

# --- MinIO (S3-compatible storage) ---
# MinIO endpoint (internal Docker network in prod, localhost in dev)
MINIO_ENDPOINT=localhost:9000
# MinIO access key (username)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key (password)
MINIO_SECRET_KEY=minioadmin

# --- SMTP (Email) ---
# SMTP server hostname
SMTP_HOST=
# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP username
SMTP_USER=
# SMTP password
SMTP_PASS=
# From address for outgoing emails
SMTP_FROM=noreply@connexo.com.br

# --- CORS ---
# Allowed origin for CORS (use * for development, specific domain for production)
# Example: CORS_ALLOWED_ORIGIN=https://connexo.com.br
CORS_ALLOWED_ORIGIN=*

# --- Application ---
# HTTP address the API server listens on
CONNEXO_HTTP_ADDR=:8080
# Application environment (development | production)
APP_ENV=development

# --- Frontend (Vite) ---
# API URL for the frontend (usually /api when behind nginx proxy)
VITE_API_URL=/api
